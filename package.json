    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "typescript": "^5",
    "vitest": "^4.0.18"
