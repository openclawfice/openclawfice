  "keywords": [
    "openclaw",
    "ai-agents",
    "dashboard",
    "virtual-office",
    "agent-collaboration",
    "async-teams",
    "retro",
    "pixel-art",
    "sims-style",
    "agent-monitoring",
    "multi-agent",
    "agent-management",
    "developer-tools",
    "productivity"
  ],
  "license": "AGPL-3.0",
  "author": "OpenClaw Community",
  "repository": {
    "type": "git",
    "url": "https://github.com/openclawfice/openclawfice"
  },
  "bin": {
    "openclawfice": "./bin/openclawfice.js"
  },
  "scripts": {
    "dev": "next dev -p 3333 --turbopack",
    "build": "next build",
    "start": "next start -p 3333",
